<?xml version="1.0" encoding="utf-8"?>
<Container version="2">
  <Name>RustPad</Name>
  <Repository>ghcr.io/ubermetroid/rustpad:latest</Repository>
  <Registry>https://github.com/UberMetroid/RustPad/pkgs/container/rustpad</Registry>
  <Github>https://github.com/UberMetroid/RustPad</Github>
  <Network>bridge</Network>
  <Privileged>false</Privileged>
  <Overview>
    RustPad is a self-hosted, lightweight notepad and collaborative text editing application built in Rust with Yew and Axum.
  </Overview>
  <Category>Productivity:Office Tools:Utilities</Category>
  <WebUI>http://[IP]:[PORT:4402]/</WebUI>
  <Icon>https://raw.githubusercontent.com/UberMetroid/RustPad/main/frontend/Assets/rustpad.png</Icon>
  
  <!-- Port Mapping -->
  <Config Name="Host Port" Target="4402" Default="4402" Mode="tcp" Description="Container Port 4402" Type="Port" Display="always" Required="true" Mask="false">4402</Config>
  
  <!-- Path Mapping -->
  <Config Name="App Data" Target="/app/data" Default="/mnt/user/appdata/rustpad" Mode="rw" Description="Location to store text notepad database files" Type="Path" Display="always" Required="true" Mask="false">/mnt/user/appdata/rustpad</Config>
  
  <!-- Variables -->
  <Config Name="Access PIN" Target="RUSTPAD_PIN" Default="" Description="Optional access PIN to secure notepads. Leave empty for public mode." Type="Variable" Display="always" Required="false" Mask="true"></Config>
  
  <Config Name="Site Title" Target="RUSTPAD_TITLE" Default="RustPad" Description="Custom notepad title rendered in header." Type="Variable" Display="always" Required="false" Mask="false">RustPad</Config>
</Container>
